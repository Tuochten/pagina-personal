---
import { getCollection } from 'astro:content';
import Shell from '../layouts/Shell.astro';
import Hero from '../components/Hero.astro';
import HomeSidebar from '../components/HomeSidebar.astro';
import FeaturedCarousel from '../components/FeaturedCarousel.tsx';
import PostListIsland from '../components/PostListIsland.tsx';
import { ACCENT_MAP } from '../consts';
import '../styles/home.css';

const allPosts = await getCollection('posts');

// Ordena por fecha descendente
const sorted = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Serializa a plain object para pasar a islas React (no pueden recibir objetos Astro)
function toPostItem(entry: typeof sorted[number]) {
  return {
    id:          entry.id,
    title:       entry.data.title,
    description: entry.data.description,
    date:        entry.data.date.toLocaleDateString('es-CL', {
      day: '2-digit', month: 'long', year: 'numeric',
    }),
    tags:        entry.data.tags,
    glyph:       entry.data.glyph,
    accentColor: ACCENT_MAP[entry.data.accent],
    readTime:    entry.data.readTime,
    href:        `/blog/${entry.id}`,
  };
}

const featured  = sorted.filter(p => p.data.featured);
// Carousel: destacados primero, luego los más recientes hasta completar 5
const carouselBase  = [...featured, ...sorted.filter(p => !p.data.featured).slice(0, 3)];
const carouselPosts = carouselBase.slice(0, 5).map(toPostItem);

// Lista: posts que no son featured
const listPosts = sorted.filter(p => !p.data.featured).map(toPostItem);
---

<Shell
  title="wladi.dev — Blog"
  description="Blog de Wladimir Aqueveque: Dev, Webflow, Ciberseguridad y Homelab."
  activeNav="Blog"
>
  <Hero variant="cinema" />

  <div class="body-grid">
    <main class="main">
      {carouselPosts.length > 0 && (
        <FeaturedCarousel posts={carouselPosts} client:load />
      )}
      <PostListIsland posts={listPosts} client:load />
    </main>

    <HomeSidebar />
  </div>
</Shell>
